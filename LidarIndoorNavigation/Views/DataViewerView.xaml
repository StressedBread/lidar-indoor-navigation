<Window x:Class="LidarIndoorNavigation.Views.DataViewerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:LidarIndoorNavigation.Views"
        mc:Ignorable="d"
        Style="{StaticResource MaterialDesignWindow}"
        Title="Data Viewer" SizeToContent="WidthAndHeight" ResizeMode="NoResize" MinWidth="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--Title Bar-->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="3"
                Margin="5,5,5,0"
                Padding="12,10">
            <TextBlock Text="Robot Telemetry"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!--Content-->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="3,0,3,3"
                Margin="5,0,5,5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!--Sector Risks-->
                <Border Grid.Row="0"
                        BorderBrush="{StaticResource MaterialDesignDivider}"
                        BorderThickness="0,0,0,2"
                        Padding="10">
                    <StackPanel>
                        <TextBlock Text="Sector Risks"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding SectorRisks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding SectorNumber}" FontSize="14" Width="80" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Risk}" FontSize="14" Width="50" TextAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!--Frontal Risk and Angle-->
                <Border Grid.Row="1"
                        BorderBrush="{StaticResource MaterialDesignDivider}"
                        BorderThickness="0,0,0,2"
                        Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Frontal Risk" FontSize="16" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FrontalRisk, StringFormat='{}{0:F2}'}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,0,0,8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Angle" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Angle, StringFormat='{}{0:F2}°'}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,0,0,0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Magnitude" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Magnitude, StringFormat='{}{0:F2}°'}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </Grid>
                </Border>

                <!--Command-->
                <Border Grid.Row="2"
                        Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Command" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Command}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>